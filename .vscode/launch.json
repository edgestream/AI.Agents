{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch AGUIServer",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}/src/AI.Web.AGUIServer/AI.Web.AGUIServer.csproj",
            "preLaunchTask": "build",
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "{0}/health"
            }
        }
    ]
}