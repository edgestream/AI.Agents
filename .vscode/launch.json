{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch AGUIChat",
            "type": "node",
            "request": "launch",
            "cwd": "${workspaceFolder}/src/AI.Web.AGUIChat",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "dev"],
            "console": "integratedTerminal",
            "resolveSourceMapLocations": [
                "${workspaceFolder}/**",
                "!**/node_modules/**",
                "!**/.next/**"
            ],
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "Now listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s/health"
            }
        },
        {
            "name": "Launch AGUIServer",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}/src/AI.Web.AGUIServer/AI.Web.AGUIServer.csproj",
            "preLaunchTask": "build"
        }
    ],
    "compounds": [
        {
            "name": "Fullstack (Server + Chat)",
            "configurations": ["Launch AGUIServer", "Launch AGUIChat"],
            "stopAll": true
        }
    ]
}