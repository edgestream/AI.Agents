{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch AGUIChat",
            "type": "node",
            "request": "launch",
            "preLaunchTask": "npm install (AGUIChat)",
            "cwd": "${workspaceFolder}/src/AI.AGUI.Web",
            "runtimeExecutable": "npm",
            "runtimeArgs": ["run", "dev"],
            "console": "integratedTerminal",
            "serverReadyAction": {
                "pattern": "- Local:.+(https?://\\S+)",
                "uriFormat": "%s",
                "action": "openExternally"
            },
            "resolveSourceMapLocations": [
                "${workspaceFolder}/**",
                "!**/node_modules/**",
                "!**/.next/**"
            ]
        },
        {
            "name": "Launch AGUIServer",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}/src/AI.AGUI.Server/AI.AGUI.Server.csproj",
            "preLaunchTask": "build"
        }
    ],
    "compounds": [
        {
            "name": "Fullstack (Server + Chat)",
            "configurations": ["Launch AGUIServer", "Launch AGUIChat"],
            "stopAll": true
        }
    ]
}