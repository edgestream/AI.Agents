{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "AGUI.Web",
            "type": "node-terminal",
            "request": "launch",
            "preLaunchTask": "npm install (AGUIChat)",
            "cwd": "${workspaceFolder}/src/AI.AGUI.Web",
            "command": "npm run dev",
            "resolveSourceMapLocations": [
                "${workspaceFolder}/**",
                "!**/node_modules/**",
                "!**/.next/**"
            ],
            "serverReadyAction": {
                "pattern": "Ready in",
                "uriFormat": "http://localhost:3000",
                "action": "openPreview"
            }
        },
        {
            "name": "AGUI.Server",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}/src/AI.AGUI.Server/AI.AGUI.Server.csproj",
            "preLaunchTask": "build"
        },
        {
            "name": "Samples (MealPlanner)",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}/samples/MealPlanner/MealPlanner.csproj",
            "preLaunchTask": "build (MealPlanner)"
        },
        {
            "name": "Local browser",
            "type": "editor-browser",
            "request": "launch",
            "url": "http://localhost:3000",
            "preLaunchTask": "wait-for-web"
        }
    ],
    "compounds": [
        {
            "name": "Fullstack (Server + Web)",
            "configurations": ["AGUI.Server", "AGUI.Web", "Local browser"],
            "stopAll": true
        }
    ]
}