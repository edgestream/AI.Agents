{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Agents.Web",
            "type": "node-terminal",
            "request": "launch",
            "preLaunchTask": "npm install (Web)",
            "cwd": "${workspaceFolder}/src/Web",
            "command": "npm run dev",
            "envFile": "${workspaceFolder}/.env",
            "env": {
                "LOG_LEVEL": "debug",
                "NODE_OPTIONS": "--enable-source-maps"
            },
            "resolveSourceMapLocations": [
                "${workspaceFolder}/**",
                "!**/node_modules/**",
                "!**/.next/**"
            ],
            "serverReadyAction": {
                "pattern": "Ready in",
                "uriFormat": "http://localhost:3000",
                "action": "openPreview"
            }
        },
        {
            "name": "Agents.Server",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}/src/Server/Server.csproj",
            "preLaunchTask": "build"
        },
        {
            "name": "Samples (FakeNews)",
            "type": "dotnet",
            "request": "launch",
            "projectPath": "${workspaceFolder}/samples/FakeNews/FakeNews.csproj",
            "preLaunchTask": "build"
        }
    ],
    "compounds": [
        {
            "name": "Fullstack (Server + Web)",
            "configurations": ["Agents.Server", "Agents.Web"],
            "stopAll": true
        }
    ]
}